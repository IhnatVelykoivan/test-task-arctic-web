# Frontend environment variables

# Public base URL of the API as seen by the browser.
# Inlined into the client bundle at build time, so the browser uses this
# value to call the API. Must be a host-reachable URL.
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Optional: base URL the Next.js server (server components, route handlers)
# uses to call the API. Read at runtime, no rebuild needed. In docker-compose
# this is set to the backend service name; left unset locally so it falls
# back to NEXT_PUBLIC_API_URL.
# API_BASE_URL=http://backend:3001/api
